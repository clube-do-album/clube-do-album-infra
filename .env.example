# Postgres
POSTGRES_DB=clube_do_album
POSTGRES_USER=clube
POSTGRES_PASSWORD=clube
POSTGRES_PORT=15432

# RabbitMQ
RABBITMQ_DEFAULT_USER=clube
RABBITMQ_DEFAULT_PASS=clube
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Seguranca compartilhada (gateway + identity precisam do MESMO segredo)
JWT_SECRET=clube-do-album-local-development-secret-key-change-me

# Catalog -> integracao Spotify (opcional para subir, necessario para importar albuns)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
