# DigitalOcean single-droplet production example.
# Copy to .env.prod on the server and replace all CHANGE_ME values.

POSTGRES_DB=clube_do_album
POSTGRES_USERNAME=clube
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_PORT=15432

RABBITMQ_USERNAME=clube
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_RABBITMQ_PASSWORD
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://clube:CHANGE_ME_STRONG_RABBITMQ_PASSWORD@rabbitmq:5672
RABBITMQ_EXCHANGE=clube-do-album.events
RABBITMQ_DEAD_LETTER_EXCHANGE=clube-do-album.dead-letter

JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
JWT_EXPIRATION_SECONDS=3600

SPOTIFY_CLIENT_ID=19b591d175914116aa070956bfc62987
SPOTIFY_CLIENT_SECRET=f25a9a85f1384b3fafbbc2730143e742

CORS_ALLOWED_ORIGINS=http://162.243.61.25

WEB_PORT=80
GATEWAY_API_PORT=3000
IDENTITY_API_PORT=8081
CATALOG_API_PORT=3001
RATINGS_API_PORT=8082
RANKING_WORKER_PORT=3002
FEED_WORKER_PORT=3003
SOCIAL_API_PORT=3004
NOTIFICATION_WORKER_PORT=3005

IDENTITY_DATABASE_URL=jdbc:postgresql://postgres:5432/clube_do_album_identity
CATALOG_DATABASE_URL=postgresql://clube:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/clube_do_album_catalog
RATINGS_DATABASE_URL=jdbc:postgresql://postgres:5432/clube_do_album_ratings
RANKING_DATABASE_URL=postgresql://clube:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/clube_do_album_ranking
SOCIAL_DATABASE_URL=postgresql://clube:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/clube_do_album_social
FEED_DATABASE_URL=postgresql://clube:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/clube_do_album_feed
NOTIFICATION_DATABASE_URL=postgresql://clube:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/clube_do_album_notification

ALBUM_IMPORTED_ROUTING_KEY=album.imported
ALBUM_RATED_ROUTING_KEY=album.rated
USER_FOLLOWED_ROUTING_KEY=user.followed
RANKING_UPDATED_ROUTING_KEY=ranking.updated

RANKING_ALBUM_IMPORTED_QUEUE=ranking.album-imported.queue
RANKING_ALBUM_RATED_QUEUE=ranking.album-rated.queue
FEED_ALBUM_RATED_QUEUE=feed.album-rated.queue
FEED_USER_FOLLOWED_QUEUE=feed.user-followed.queue
NOTIFICATION_ALBUM_RATED_QUEUE=notification.album-rated.queue
NOTIFICATION_USER_FOLLOWED_QUEUE=notification.user-followed.queue
NOTIFICATION_RANKING_UPDATED_QUEUE=notification.ranking-updated.queue
